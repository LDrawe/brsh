{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "types": ["node"],
    "module": "commonjs",
    "rootDir": ".",
    "paths": {
      "@config/*": [
        "./src/config/*"
      ],
      "@core/*": [
        "./src/core/*"
      ],
      "@cli/*": [
        "./src/cli/*"
      ],
      "types/*": [
        "./src/types/*"
      ]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}