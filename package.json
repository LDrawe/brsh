{
  "name": "trabalho-so",
  "version": "1.0.0",
  "description": "Uma simples CLI para tratar sistemas de arquivos",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "tsx --test src/**/*.spec.ts",
    "start:bun": "bun run src/index.ts",
    "compile:bun": "bun build src/index.ts --compile --outfile brsh",
    "start:deno": "deno run --allow-read --allow-write src/index.ts",
    "compile:deno": "deno compile --allow-read --allow-write --output brsh src/index.ts"
  },
  "keywords": [],
  "author": "Eduardo Portilho <eduardomportilho@hotmail.com>",
  "license": "MIT",
  "private": "true",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cli-color": "^2.0.2",
    "@types/node": "^26.0.0",
    "@types/prompt-sync": "^4.1.1",
    "@typescript-eslint/eslint-plugin": "^5.30.3",
    "@typescript-eslint/parser": "^5.30.3",
    "eslint": "^8.19.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.2.3",
    "eslint-plugin-promise": "^6.0.0",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cli-color": "^2.0.2",
    "dree": "^3.3.7",
    "prompt-sync": "^4.2.0"
  }
}
